      },
      {
        "id": "https://economic-research.bnpparibas.com/html/en-US/Markets-Overview-12-January-2026-1/13/2026,53132",
        "title": "Markets Overview - 12 January 2026",
        "link": "https://economic-research.bnpparibas.com/html/en-US/Markets-Overview-12-January-2026-1/13/2026,53132",
        "content": "Equity indices, Currencies & commodities, and Bond markets.",
        "fullContent": "Equity indices, Currencies & commodities, and Bond markets.",
        "author": "tarik.rharrab@bnpparibas.com",
