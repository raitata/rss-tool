        "title": "FinancialJuice: Cuba's national electric grid collapses - Cuba's national electric union",
        "link": "https://www.financialjuice.com/News/9497940/Cubas-national-electric-grid-collapses---Cubas-national-electric-union.aspx?xy=rss",
        "content": "",
        "fullContent": "",
        "author": "FinancialJuice",
        "date": "2026-03-21T23:05:23.000Z",
        "image": null
      },
